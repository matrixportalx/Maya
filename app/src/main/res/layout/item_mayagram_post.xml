<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:background="?attr/colorSurface"
    android:elevation="2dp">

    <!-- Header: Avatar + İsim + Zaman + Sil -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Avatar alanı (fotoğraf veya emoji) -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp">

            <ImageView
                android:id="@+id/mg_avatar_image"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Avatar" />

            <TextView
                android:id="@+id/mg_avatar_emoji"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="22sp"
                android:text="🤖" />

        </FrameLayout>

        <!-- İsim + Zaman -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/mg_char_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/mg_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:text="Az önce" />

        </LinearLayout>

        <!-- Sil butonu -->
        <TextView
            android:id="@+id/mg_btn_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="🗑"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- Gönderi görüntüsü (varsa) -->
    <ImageView
        android:id="@+id/mg_post_image"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/colorSurfaceVariant"
        android:contentDescription="Gönderi görüntüsü" />

    <!-- Caption -->
    <TextView
        android:id="@+id/mg_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:paddingBottom="4dp"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.35"
        android:textColor="?attr/colorOnSurface" />

    <!-- v6.10: "Maya ve 2 kişi beğendi" satırı — beğeni yoksa GONE olur (adapter ayarlar) -->
    <TextView
        android:id="@+id/mg_liked_by"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone" />

    <!-- Aksiyon çubuğu: Like + Yorum -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/mg_btn_like"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:text="🤍 0"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/mg_btn_comment"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:text="💬 Yorum"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Alt çizgi -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorSurfaceVariant" />

</LinearLayout>
