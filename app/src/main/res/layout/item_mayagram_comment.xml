<?xml version="1.0" encoding="utf-8"?>
<!-- layout/item_mayagram_comment.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:gravity="top">

    <!-- v6.5: Reply girintisi — yalnızca parentCommentId varsa genişler -->
    <View
        android:id="@+id/mgc_reply_indent_space"
        android:layout_width="0dp"
        android:layout_height="1dp" />

    <!-- Avatar -->
    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp">

        <ImageView
            android:id="@+id/mgc_avatar_image"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Avatar" />

        <TextView
            android:id="@+id/mgc_avatar_emoji"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textSize="16sp"
            android:text="👤" />

    </FrameLayout>

    <!-- İçerik -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/mgc_author_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/mgc_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- v6.5: Yanıt verilen yorumun yazarı (reply ise görünür) -->
        <TextView
            android:id="@+id/mgc_reply_to"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/accent_warm"
            android:visibility="gone"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/mgc_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginTop="2dp" />

        <!-- v6.5: Yanıtla butonu -->
        <TextView
            android:id="@+id/mgc_btn_reply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="↩ Yanıtla"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

</LinearLayout>
