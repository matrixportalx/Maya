<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:orientation="horizontal">

    <!-- Sol: Avatar + İndeks -->
    <LinearLayout
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/msg_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="22sp"
            android:text="🤖" />

        <TextView
            android:id="@+id/msg_index"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="10sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:fontFamily="monospace"
            android:text="#0" />

    </LinearLayout>

    <!-- Sağ: İsim + Zaman + Thinking + Mesaj + Butonlar -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- İsim + Zaman -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/msg_sender_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/dark_sender_assistant"
                android:textStyle="bold"
                android:text="Asistan" />

            <TextView
                android:id="@+id/msg_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="monospace"
                android:text="00:00:00" />

        </LinearLayout>

        <!-- Thinking block (varsayılan: gizli) -->
        <LinearLayout
            android:id="@+id/thinking_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="?attr/colorSurfaceVariant"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <!-- Başlık satırı (tıklanabilir) -->
            <LinearLayout
                android:id="@+id/thinking_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💭 Düşünce süreci"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/thinking_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▾"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:paddingStart="4dp" />
            </LinearLayout>

            <!-- Thinking içeriği -->
            <TextView
                android:id="@+id/thinking_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:padding="8dp"
                android:paddingTop="0dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textIsSelectable="true" />
        </LinearLayout>

        <!-- Asistan mesaj balonu -->
        <TextView
            android:id="@+id/msg_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="260dp"
            android:background="@drawable/bg_assistant_message"
            android:padding="12dp"
            android:lineSpacingMultiplier="1.3"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:textIsSelectable="true"
            android:textColorLink="?android:textColorLink" />

        <!-- Aksiyon butonları: 📋 + t/s solda, 🔄 sağda -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <!-- Kopyala (sol) -->
            <Button
                android:id="@+id/btn_copy"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="14sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />

            <!-- t/s göstergesi -->
            <TextView
                android:id="@+id/txt_tps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />

            <!-- Ortadaki boşluk -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Yeniden oluştur (sağ) -->
            <Button
                android:id="@+id/btn_regenerate"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄"
                android:textSize="14sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
