<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:orientation="horizontal">

    <!-- Sol: Avatar + İndeks -->
    <LinearLayout
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/msg_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="22sp"
            android:text="👤" />

        <TextView
            android:id="@+id/msg_index"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="10sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:fontFamily="monospace"
            android:text="#0" />

    </LinearLayout>

    <!-- Sağ: İsim + Zaman + Baloncuk + Butonlar -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- İsim + Zaman -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/msg_sender_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/dark_sender_user"
                android:textStyle="bold"
                android:text="Kullanıcı" />

            <TextView
                android:id="@+id/msg_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="monospace"
                android:text="00:00:00" />

        </LinearLayout>

        <!-- Mesaj baloncuğu (sağa hizalı) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end">

            <TextView
                android:id="@+id/msg_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="260dp"
                android:background="@drawable/bg_user_message"
                android:padding="12dp"
                android:lineSpacingMultiplier="1.3"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textIsSelectable="true" />

        </LinearLayout>

        <!-- Butonlar (sağa hizalı) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="0dp">

            <Button
                android:id="@+id/btn_edit"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️"
                android:textSize="14sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />

            <Button
                android:id="@+id/btn_copy"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="14sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
